# Template. Easiest path: run `python setup.py` to generate .env for you.
# Or copy this to .env and fill it in. .env is gitignored — never commit it.

# Anthropic API key (the anthropic SDK reads this from the environment automatically).
ANTHROPIC_API_KEY=

# Triage model. Default claude-sonnet-4-6 (strong summaries); use claude-haiku-4-5
# for a cheaper/faster run.
MODEL=claude-sonnet-4-6

# Microsoft Graph public client (NOT a secret). The default below is Microsoft's
# first-party "Graph Command Line Tools" public client — works for personal accounts.
MS_CLIENT_ID=14d82eec-204b-4c2f-b7e8-296a70dab67e

# Authority:
#   https://login.microsoftonline.com/consumers      (personal accounts)
#   https://login.microsoftonline.com/<tenant-id>     (work/school)
#   https://login.microsoftonline.com/common          (either)
MS_TENANT_AUTHORITY=https://login.microsoftonline.com/consumers
